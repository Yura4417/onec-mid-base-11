#Область ОбработчикиСобытий
//--Варламов 20.02.2026
// Обработчик события получения представления контактного лица.
// Если заполнено поле "Действует на основании", добавляет его к представлению.
//
// Параметры:
//   Данные - Структура - данные объекта
//   Представление - Строка - формируемое представление
//   СтандартнаяОбработка - Булево - флаг стандартной обработки
//
Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	ДействуетНаОсновании = Данные.Ссылка.ДействуетНаОсновании;

	Если ЗначениеЗаполнено(ДействуетНаОсновании) Тогда

		СтандартнаяОбработка = Ложь;
		Представление = СокрЛП(Данные.Наименование) + " (действует на основании: " + СокрЛП(ДействуетНаОсновании) + ")";

	КонецЕсли;
	
КонецПроцедуры
//--Варламов 20.02.2026

#КонецОбласти

