#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Добавляет элемент формы "Контактное лицо" сразу после поля "Договор"
//
// Параметры:
//   Форма - ФормаКлиентскогоПриложения - форма документа
//
Процедура ДобавитьПолеКонтактноеЛицо(Форма) Экспорт

	// Находим элемент Договор на форме для определения родительской группы
	ЭлементДоговор = Форма.Элементы.Найти("Договор");

	Если ЭлементДоговор = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// Определяем родительскую группу (ГруппаШапкаПраво или корень формы)
	Родитель = ЭлементДоговор.Родитель;

	// Определяем элемент, ПЕРЕД которым нужно вставить поле
	// Нам нужно вставить ПОСЛЕ Договора, значит берём следующий элемент в группе
	ЭлементПеред = Неопределено;
	НашлиДоговор = Ложь;

	Для Каждого ЭлементГруппы Из Родитель.ПодчиненныеЭлементы Цикл

		Если НашлиДоговор Тогда

			ЭлементПеред = ЭлементГруппы;
			Прервать;

		КонецЕсли;

		Если ЭлементГруппы = ЭлементДоговор Тогда

			НашлиДоговор = Истина;

		КонецЕсли;

	КонецЦикла;

	// Вставляем поле перед найденным элементом (или в конец группы, если Договор последний)
	ПолеКонтактноеЛицо = Форма.Элементы.Вставить("Расш1_КонтактноеЛицо", Тип("ПолеФормы"), Родитель, ЭлементПеред);
	ПолеКонтактноеЛицо.Вид = ВидПоляФормы.ПолеВвода;
	ПолеКонтактноеЛицо.ПутьКДанным = "Объект.Расш1_КонтактноеЛицо";
	ПолеКонтактноеЛицо.Заголовок = "Контактное лицо";

КонецПроцедуры

// Добавляет поле "Согласованная скидка (%)" и кнопку "Пересчитать по скидке"
// на форму документа ЗаказПокупателя
//
// Параметры:
//   Форма - ФормаКлиентскогоПриложения - форма документа
//
Процедура ДобавитьПолеСогласованнаяСкидка(Форма) Экспорт

	// Ищем элемент "Организация" для определения места вставки
	ЭлементОрганизация = Форма.Элементы.Найти("Организация");
	Если ЭлементОрганизация = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// ГруппаШапкаЛево — родитель Организация
	РодительОрганизация = ЭлементОрганизация.Родитель;

	// Создаём горизонтальную группу для поля скидки и кнопки
	ГруппаСкидки = Форма.Элементы.Вставить(
		"Расш1_ГруппаСкидки", Тип("ГруппаФормы"), РодительОрганизация);
	ГруппаСкидки.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаСкидки.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяЕслиВозможно;
	ГруппаСкидки.ОтображатьЗаголовок = Ложь;

	// Поле ввода скидки
	ПолеСкидки = Форма.Элементы.Вставить(
		"Расш1_СогласованнаяСкидка", Тип("ПолеФормы"), ГруппаСкидки);
	ПолеСкидки.Вид = ВидПоляФормы.ПолеВвода;
	ПолеСкидки.ПутьКДанным = "Объект.Расш1_СогласованнаяСкидка";
	ПолеСкидки.Заголовок = "Согласованная скидка (%)";
	ПолеСкидки.УстановитьДействие("ПриИзменении", "Подключаемый_Расш1_СогласованнаяСкидкаПриИзменении");

	Команда = Форма.Команды.Добавить("Расш1_ПересчитатьПоСкидке");
	Команда.Действие = "Расш1_ПересчитатьПоСкидке";
	Команда.Заголовок = "Пересчитать по скидке";

	// Кнопка пересчёта
	КнопкаПересчета = Форма.Элементы.Вставить(
		"Расш1_КнопкаПересчитатьПоСкидке", Тип("КнопкаФормы"), ГруппаСкидки);
	КнопкаПересчета.ИмяКоманды = "Расш1_ПересчитатьПоСкидке";
	КнопкаПересчета.Заголовок = "Пересчитать по скидке";

КонецПроцедуры



#КонецОбласти

#КонецЕсли
